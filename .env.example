# Copy to .env and adjust as needed. Never commit the real .env file.

APP_NAME="Intelligent Credit Card Rewards Agent"
APP_ENV=local
APP_DEBUG=true

# Postgres (matches docker-compose.yml's "db" service by default)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=credit_card_rewards

# Anthropic Claude - required from Phase 2 onward (Intent Classification + Final Answer
# nodes are the only two LLM-touching nodes; every other node stays deterministic).
ANTHROPIC_API_KEY=
LLM_INTENT_MODEL=claude-haiku-4-5
LLM_FINAL_ANSWER_MODEL=claude-sonnet-5

# Optional: set these two to enable LangSmith tracing (Section 19) - LangChain/LangGraph
# auto-detect them, no code change needed.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
