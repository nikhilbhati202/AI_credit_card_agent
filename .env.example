# Copy to .env and adjust as needed. Never commit the real .env file.

APP_NAME="Intelligent Credit Card Rewards Agent"
APP_ENV=local
APP_DEBUG=true

# Postgres (matches docker-compose.yml's "db" service by default)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=credit_card_rewards

# LLM endpoint (Intent Classification + Final Answer are the only two LLM-touching nodes;
# every other node stays deterministic). Point LLM_BASE_URL at any OpenAI-chat-completions-
# compatible server, e.g. Ollama running in a free Colab GPU notebook and tunneled out via
# cloudflared. See COLAB_SETUP.md for the full step-by-step notebook. LLM_API_KEY is a
# free-form placeholder such servers don't check.
LLM_BASE_URL=
LLM_API_KEY=not-needed
LLM_INTENT_MODEL=qwen2.5:7b-instruct
LLM_FINAL_ANSWER_MODEL=qwen2.5:7b-instruct
#
# Per-attempt LLM call timeout in seconds. 90 comfortably covers a self-hosted/Colab-tunneled
# model's cold start (~50-60s observed); lower this if using a fast commercial API and you'd
# rather fail fast.
LLM_TIMEOUT_SECONDS=90

# Optional: set these two to enable LangSmith tracing (Section 19) - LangChain/LangGraph
# auto-detect them, no code change needed.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
