# Copy to .env and adjust as needed. Never commit the real .env file.

APP_NAME="Intelligent Credit Card Rewards Agent"
APP_ENV=local
APP_DEBUG=true

# Postgres (matches docker-compose.yml's "db" service by default)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=credit_card_rewards

# LLM provider (Intent Classification + Final Answer are the only two LLM-touching nodes;
# every other node stays deterministic). Two options - pick one:
#
# 1) "openai_compatible" (default, no paid API key): point LLM_BASE_URL at any
#    OpenAI-chat-completions-compatible server, e.g. Ollama running in a free Colab GPU
#    notebook and tunneled out via ngrok/cloudflared. See COLAB_SETUP.md for the full
#    step-by-step notebook. LLM_API_KEY is a free-form placeholder such servers don't check.
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=
LLM_API_KEY=not-needed
LLM_INTENT_MODEL=qwen2.5:7b-instruct
LLM_FINAL_ANSWER_MODEL=qwen2.5:7b-instruct
#
# 2) "anthropic": uncomment these three and set LLM_PROVIDER=anthropic above.
# ANTHROPIC_API_KEY=
# LLM_INTENT_MODEL=claude-haiku-4-5
# LLM_FINAL_ANSWER_MODEL=claude-sonnet-5
#
# Per-attempt LLM call timeout in seconds. 90 comfortably covers a self-hosted/Colab-tunneled
# model's cold start (~50-60s observed); lower this if using a fast commercial API and you'd
# rather fail fast.
LLM_TIMEOUT_SECONDS=90

# Optional: set these two to enable LangSmith tracing (Section 19) - LangChain/LangGraph
# auto-detect them, no code change needed.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
